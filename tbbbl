# ============================================================
# REPOSITÓRIO DE TABELAS MARKDOWN
# ============================================================

class TabelasMarkdown:

    def __init__(self):

        self.itens = {}

    # ========================================================
    # UTILITÁRIOS
    # ========================================================

    @staticmethod
    def _escapar_markdown(valor):

        return (
            str(valor)
            .replace("|", r"\|")
            .replace("\n", " ")
            .replace("\r", " ")
        )

    @staticmethod
    def _formatar_inteiro(valor):

        return (
            f"{int(valor):,}"
            .replace(",", ".")
        )

    @staticmethod
    def _formatar_decimal(
        valor,
        casas_decimais=2,
    ):

        texto = f"{float(valor):,.{casas_decimais}f}"

        return (
            texto
            .replace(",", "__MILHAR__")
            .replace(".", ",")
            .replace("__MILHAR__", ".")
        )

    def _formatar_percentual(
        self,
        valor,
        casas_decimais=2,
        valor_em_fracao=False,
    ):

        numero = float(valor)

        if valor_em_fracao:
            numero = numero * 100

        return (
            self._formatar_decimal(
                numero,
                casas_decimais,
            )
            + "%"
        )

    def _formatar_moeda(
        self,
        valor,
        casas_decimais=2,
    ):

        return (
            "R$ "
            + self._formatar_decimal(
                valor,
                casas_decimais,
            )
        )

    @staticmethod
    def _parece_percentual(nome_coluna):

        nome = nome_coluna.upper()

        prefixos = (
            "PC_",
            "PCT_",
            "PERC_",
            "PERCENTUAL_",
        )

        termos = (
            "PERCENTUAL",
            "PERCENT",
            "% DA BASE",
            "%_BASE",
            "TAXA",
        )

        return (
            nome.startswith(prefixos)
            or any(
                termo in nome
                for termo in termos
            )
        )

    @staticmethod
    def _parece_quantidade(nome_coluna):

        nome = nome_coluna.upper()

        prefixos = (
            "QT_",
            "QTD_",
            "NR_",
        )

        termos = (
            "QUANTIDADE",
            "CLIENTES",
            "CONTAGEM",
            "COUNT",
            "TOTAL_REGISTROS",
            "TOTAL_CLIENTES",
        )

        return (
            nome.startswith(prefixos)
            or any(
                termo in nome
                for termo in termos
            )
        )

    @staticmethod
    def _parece_moeda(nome_coluna):

        nome = nome_coluna.upper()

        prefixos = (
            "VL_",
            "VALOR_",
        )

        termos = (
            "RECEITA",
            "DESPESA",
            "SALDO",
            "RENDA",
            "FATURAMENTO",
        )

        return (
            nome.startswith(prefixos)
            or any(
                termo in nome
                for termo in termos
            )
        )

    # ========================================================
    # FORMATAÇÃO DE VALORES
    # ========================================================

    def _formatar_valor(
        self,
        valor,
        nome_coluna,
        tipo_spark,
        formato=None,
        casas_decimais=2,
        percentual_fracao=False,
    ):

        if valor is None:
            return ""

        # ----------------------------------------------------
        # FORMATO EXPLICITAMENTE DEFINIDO
        # ----------------------------------------------------

        if formato == "texto":

            return self._escapar_markdown(valor)

        if formato == "inteiro":

            return self._formatar_inteiro(valor)

        if formato == "decimal":

            return self._formatar_decimal(
                valor,
                casas_decimais,
            )

        if formato == "percentual":

            return self._formatar_percentual(
                valor,
                casas_decimais,
                valor_em_fracao=False,
            )

        if formato == "percentual_fracao":

            return self._formatar_percentual(
                valor,
                casas_decimais,
                valor_em_fracao=True,
            )

        if formato == "moeda":

            return self._formatar_moeda(
                valor,
                casas_decimais,
            )

        if formato == "data":

            if hasattr(valor, "strftime"):

                return valor.strftime(
                    "%d/%m/%Y"
                )

            return self._escapar_markdown(valor)

        if formato == "data_hora":

            if hasattr(valor, "strftime"):

                return valor.strftime(
                    "%d/%m/%Y %H:%M:%S"
                )

            return self._escapar_markdown(valor)

        if formato == "booleano":

            return (
                "Sim"
                if bool(valor)
                else "Não"
            )

        # ----------------------------------------------------
        # DETECÇÃO PELO NOME DA COLUNA
        # ----------------------------------------------------

        if self._parece_percentual(
            nome_coluna
        ):

            return self._formatar_percentual(
                valor,
                casas_decimais,
                valor_em_fracao=percentual_fracao,
            )

        if self._parece_moeda(
            nome_coluna
        ):

            return self._formatar_moeda(
                valor,
                casas_decimais,
            )

        if self._parece_quantidade(
            nome_coluna
        ):

            return self._formatar_inteiro(
                valor
            )

        # ----------------------------------------------------
        # DETECÇÃO PELO TIPO SPARK
        # ----------------------------------------------------

        if isinstance(
            tipo_spark,
            (
                ByteType,
                ShortType,
                IntegerType,
                LongType,
            ),
        ):

            return self._formatar_inteiro(
                valor
            )

        if isinstance(
            tipo_spark,
            (
                FloatType,
                DoubleType,
                DecimalType,
            ),
        ):

            return self._formatar_decimal(
                valor,
                casas_decimais,
            )

        if isinstance(
            tipo_spark,
            DateType,
        ):

            return valor.strftime(
                "%d/%m/%Y"
            )

        if isinstance(
            tipo_spark,
            TimestampType,
        ):

            return valor.strftime(
                "%d/%m/%Y %H:%M:%S"
            )

        if isinstance(
            tipo_spark,
            BooleanType,
        ):

            return (
                "Sim"
                if valor
                else "Não"
            )

        if isinstance(
            valor,
            datetime,
        ):

            return valor.strftime(
                "%d/%m/%Y %H:%M:%S"
            )

        if isinstance(
            valor,
            date,
        ):

            return valor.strftime(
                "%d/%m/%Y"
            )

        return self._escapar_markdown(
            valor
        )

    # ========================================================
    # PUBLICAÇÃO DA TABELA
    # ========================================================

    def publicar(
        self,
        nome,
        dataframe,
        colunas=None,
        nomes_colunas=None,
        formatos=None,
        percentuais_fracao=None,
        casas_decimais=2,
        limite=100,
        titulo=None,
        subtitulo=None,
        observacao=None,
        ordenar_por=None,
        crescente=True,
    ):

        """
        Publica um DataFrame Spark como tabela Markdown.

        Parâmetros
        ----------
        nome:
            Nome utilizado para recuperar a tabela localmente.

        dataframe:
            DataFrame Spark que será publicado.

        colunas:
            Colunas que serão exibidas e sua ordem.
            Quando None, utiliza todas as colunas.

        nomes_colunas:
            Dicionário para alterar os cabeçalhos.

            Exemplo:
            {
                "QT_CLIENTES": "Clientes",
                "PC_BASE": "% da base"
            }

        formatos:
            Dicionário com o formato de cada coluna.

            Formatos disponíveis:
            - texto
            - inteiro
            - decimal
            - percentual
            - percentual_fracao
            - moeda
            - data
            - data_hora
            - booleano

        percentuais_fracao:
            Lista de colunas percentuais armazenadas
            entre 0 e 1.

        limite:
            Número máximo de linhas transportadas
            para o ambiente local.

        titulo:
            Título Markdown opcional.

        subtitulo:
            Texto opcional abaixo do título.

        observacao:
            Nota opcional exibida após a tabela.

        ordenar_por:
            Coluna ou lista de colunas para ordenação.
        """

        if colunas is None:

            colunas = dataframe.columns

        if nomes_colunas is None:

            nomes_colunas = {}

        if formatos is None:

            formatos = {}

        if percentuais_fracao is None:

            percentuais_fracao = []

        df_publicacao = dataframe

        # ----------------------------------------------------
        # ORDENAÇÃO
        # ----------------------------------------------------

        if ordenar_por is not None:

            if isinstance(
                ordenar_por,
                str,
            ):

                ordenar_por = [
                    ordenar_por
                ]

            expressoes_ordenacao = []

            for coluna in ordenar_por:

                if crescente:

                    expressoes_ordenacao.append(
                        F.col(coluna).asc()
                    )

                else:

                    expressoes_ordenacao.append(
                        F.col(coluna).desc()
                    )

            df_publicacao = (
                df_publicacao
                .orderBy(
                    *expressoes_ordenacao
                )
            )

        # ----------------------------------------------------
        # VALIDAÇÃO DAS COLUNAS
        # ----------------------------------------------------

        colunas_inexistentes = [
            coluna
            for coluna in colunas
            if coluna
            not in dataframe.columns
        ]

        if colunas_inexistentes:

            raise ValueError(
                "Colunas não encontradas no DataFrame: "
                + ", ".join(
                    colunas_inexistentes
                )
            )

        # ----------------------------------------------------
        # TIPOS SPARK
        # ----------------------------------------------------

        tipos = {
            campo.name: campo.dataType
            for campo
            in dataframe.schema.fields
        }

        # ----------------------------------------------------
        # COLETA LIMITADA
        # ----------------------------------------------------

        registros = (
            df_publicacao
            .select(
                *colunas
            )
            .limit(
                limite + 1
            )
            .collect()
        )

        truncada = (
            len(registros)
            > limite
        )

        registros = (
            registros[:limite]
        )

        # ----------------------------------------------------
        # CABEÇALHO
        # ----------------------------------------------------

        cabecalhos = [
            nomes_colunas.get(
                coluna,
                coluna,
            )
            for coluna in colunas
        ]

        cabecalho_markdown = (
            "| "
            + " | ".join(
                cabecalhos
            )
            + " |"
        )

        # ----------------------------------------------------
        # ALINHAMENTO
        # ----------------------------------------------------

        alinhamentos = []

        for coluna in colunas:

            tipo = tipos[coluna]

            formato = formatos.get(
                coluna
            )

            coluna_numerica = isinstance(
                tipo,
                (
                    ByteType,
                    ShortType,
                    IntegerType,
                    LongType,
                    FloatType,
                    DoubleType,
                    DecimalType,
                ),
            )

            formato_numerico = formato in (
                "inteiro",
                "decimal",
                "percentual",
                "percentual_fracao",
                "moeda",
            )

            if (
                coluna_numerica
                or formato_numerico
            ):

                alinhamentos.append(
                    "---:"
                )

            else:

                alinhamentos.append(
                    "---"
                )

        separador_markdown = (
            "| "
            + " | ".join(
                alinhamentos
            )
            + " |"
        )

        # ----------------------------------------------------
        # LINHAS
        # ----------------------------------------------------

        linhas_markdown = []

        for registro in registros:

            valores = []

            for coluna in colunas:

                valor_formatado = (
                    self._formatar_valor(
                        valor=registro[coluna],
                        nome_coluna=coluna,
                        tipo_spark=tipos[coluna],
                        formato=formatos.get(
                            coluna
                        ),
                        casas_decimais=(
                            casas_decimais
                        ),
                        percentual_fracao=(
                            coluna
                            in percentuais_fracao
                        ),
                    )
                )

                valores.append(
                    valor_formatado
                )

            linha_markdown = (
                "| "
                + " | ".join(
                    valores
                )
                + " |"
            )

            linhas_markdown.append(
                linha_markdown
            )

        # ----------------------------------------------------
        # DOCUMENTO MARKDOWN
        # ----------------------------------------------------

        partes = []

        if titulo:

            partes.extend([
                f"### {titulo}",
                "",
            ])

        if subtitulo:

            partes.extend([
                subtitulo,
                "",
            ])

        partes.extend([
            cabecalho_markdown,
            separador_markdown,
            *linhas_markdown,
        ])

        if truncada:

            partes.extend([
                "",
                (
                    f"*Exibição limitada às primeiras "
                    f"{limite} linhas.*"
                ),
            ])

        if observacao:

            partes.extend([
                "",
                f"*{observacao}*",
            ])

        markdown = "\n".join(
            partes
        )

        self.itens[nome] = markdown

        print(
            f"✅ Tabela publicada: {nome}"
        )

        print(
            f"📋 Linhas publicadas: "
            f"{len(registros)}"
        )

        if truncada:

            print(
                f"⚠️ Resultado limitado "
                f"a {limite} linhas"
            )

    # ========================================================
    # OUTROS MÉTODOS
    # ========================================================

    def remover(
        self,
        nome,
    ):

        if nome in self.itens:

            del self.itens[nome]

            print(
                f"🗑️ Tabela removida: "
                f"{nome}"
            )

        else:

            print(
                f"⚠️ Tabela não encontrada: "
                f"{nome}"
            )

    def listar(self):

        nomes = sorted(
            self.itens.keys()
        )

        print(
            "\n"
            + "=" * 100
        )

        print(
            "TABELAS MARKDOWN"
        )

        print(
            "=" * 100
        )

        if not nomes:

            print(
                "⚠️ Nenhuma tabela publicada"
            )

            return

        for i, nome in enumerate(
            nomes,
            start=1,
        ):

            print(
                f"{i:02d} -> {nome}"
            )

        print(
            "\n"
            + "=" * 100
        )

        print(
            "COPIE PARA O NOTEBOOK LOCAL"
        )

        print(
            "=" * 100
        )

        print(
            f"exibir_tabela_spark({nomes!r})"
        )

    def limpar(self):

        quantidade = len(
            self.itens
        )

        self.itens.clear()

        print(
            f"🗑️ {quantidade} "
            f"tabela(s) removida(s)"
        )


