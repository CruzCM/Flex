def exibir_tabela_spark(
    nomes,
    sessao=None,
    mostrar_cabecalho=True,
):

    """
    Exibe uma ou várias tabelas Markdown
    publicadas no ambiente Spark.

    Parâmetros
    ----------
    nomes:
        Nome da tabela ou lista de nomes.

    sessao:
        Sessão utilizada para acessar
        o ambiente Spark.

    mostrar_cabecalho:
        Exibe o nome da tabela antes
        do Markdown.
    """

    if sessao is None:

        sessao = (
            gerenciador_spark.spark
        )

    if isinstance(
        nomes,
        str,
    ):

        nomes = [nomes]

    catalogo = (
        sessao.get_from_spark(
            "tabelas_markdown.itens"
        )
    )

    if catalogo is None:

        print(
            "⚠️ O catálogo de tabelas "
            "não foi encontrado no Spark"
        )

        return

    for i, nome in enumerate(
        nomes,
        start=1,
    ):

        if mostrar_cabecalho:

            print(
                "\n"
                + "=" * 100
            )

            print(
                f"📋 {i:02d} | {nome}"
            )

            print(
                "=" * 100
            )

        if nome not in catalogo:

            print(
                f"⚠️ Tabela não encontrada: "
                f"{nome}"
            )

            continue

        markdown = catalogo[nome]

        display(
            Markdown(
                markdown
            )
        )


