from pyspark.sql import functions as F
from pyspark.sql.types import (
    StructType,
    StructField,
    IntegerType,
    StringType,
    LongType,
    DoubleType,
)


# ============================================================
# CONFIGURAÇÃO
# ============================================================

TABELA = (
    "sbx_t2i2016."
    "v1_ana_edu_fin_cli"
)


# ============================================================
# LEITURA DA BASE
# ============================================================

df_origem = spark.table(
    TABELA
)


# ============================================================
# SELEÇÃO DA EXECUÇÃO MAIS RECENTE
# ============================================================

dt_exea_max = (
    df_origem
    .agg(
        F.max(
            "DT_EXEA"
        ).alias(
            "DT_EXEA_MAX"
        )
    )
    .first()[
        "DT_EXEA_MAX"
    ]
)


df = (
    df_origem
    .filter(
        F.col("DT_EXEA")
        == F.lit(dt_exea_max)
    )
    .dropDuplicates([
        "CD_CLI"
    ])
    .cache()
)


# ============================================================
# INDICADORES EM UMA ÚNICA AGREGAÇÃO
# ============================================================

resumo = (
    df
    .agg(
        F.count(
            "*"
        ).alias(
            "TOTAL_CLIENTES"
        ),

        F.sum(
            F.when(
                F.upper(
                    F.trim(
                        F.col("NM_PRFL")
                    )
                )
                == "A CLASSIFICAR",
                1,
            ).otherwise(0)
        ).alias(
            "NM_PRFL_A_CLASSIFICAR"
        ),

        F.sum(
            F.when(
                F.upper(
                    F.trim(
                        F.col(
                            "NM_MAC_PRFL_CLI"
                        )
                    )
                )
                == "A CLASSIFICAR",
                1,
            ).otherwise(0)
        ).alias(
            "NM_MAC_PRFL_A_CLASSIFICAR"
        ),

        F.sum(
            F.when(
                F.upper(
                    F.trim(
                        F.col(
                            "FL_TEM_MOV_AGRO"
                        )
                    )
                )
                == "S",
                1,
            ).otherwise(0)
        ).alias(
            "AGRO_SIM"
        ),

        F.sum(
            F.when(
                F.col(
                    "QT_TRANS_ENT"
                )
                == 0,
                1,
            ).otherwise(0)
        ).alias(
            "ENTRADA_ZERO"
        ),

        F.sum(
            F.when(
                F.col(
                    "QT_TRANS_SAI"
                )
                == 0,
                1,
            ).otherwise(0)
        ).alias(
            "SAIDA_ZERO"
        ),

        F.sum(
            F.when(
                F.upper(
                    F.trim(
                        F.col(
                            "FL_PARTICIPA_RADAR"
                        )
                    )
                )
                == "S",
                1,
            ).otherwise(0)
        ).alias(
            "RADAR_SIM"
        ),
    )
    .first()
)


# ============================================================
# VARIÁVEIS
# ============================================================

total_clientes = int(
    resumo[
        "TOTAL_CLIENTES"
    ]
)


nm_prfl_a_classificar = int(
    resumo[
        "NM_PRFL_A_CLASSIFICAR"
    ]
)

nm_prfl_com_perfil = (
    total_clientes
    - nm_prfl_a_classificar
)


macro_a_classificar = int(
    resumo[
        "NM_MAC_PRFL_A_CLASSIFICAR"
    ]
)

macro_com_perfil = (
    total_clientes
    - macro_a_classificar
)


agro_sim = int(
    resumo[
        "AGRO_SIM"
    ]
)

agro_nao = (
    total_clientes
    - agro_sim
)


entrada_zero = int(
    resumo[
        "ENTRADA_ZERO"
    ]
)

entrada_maior_zero = (
    total_clientes
    - entrada_zero
)


saida_zero = int(
    resumo[
        "SAIDA_ZERO"
    ]
)

saida_maior_zero = (
    total_clientes
    - saida_zero
)


radar_sim = int(
    resumo[
        "RADAR_SIM"
    ]
)

radar_nao = (
    total_clientes
    - radar_sim
)


# ============================================================
# FUNÇÃO DE PERCENTUAL
# ============================================================

def calcular_percentual(
    quantidade,
):

    if total_clientes == 0:

        return 0.0

    return round(
        (
            quantidade
            / total_clientes
        )
        * 100,
        2,
