            ) == "N",

            F.lit("Não disponível"),
        )
        .otherwise(
            F.coalesce(
                F.col(
                    "NM_CLS_ENT_DOMINANTE"
                ),
                F.lit("Sem entrada"),
            )
        ),
    )

    .withColumn(
        "NM_CLS_SAI_DOMINANTE",

        F.when(
            F.col(
                "FL_BASE_TRANSACIONAL_ENCONTRADA"
            ) == "N",

            F.lit("Não disponível"),
        )
        .otherwise(
            F.coalesce(
                F.col(
                    "NM_CLS_SAI_DOMINANTE"
                ),
                F.lit("Sem saída"),
            )
        ),
    )

    .withColumn(
        "TX_ASSINATURA_FLUXO",

        F.when(
            F.col(
                "FL_BASE_TRANSACIONAL_ENCONTRADA"
            ) == "N",

            F.lit("Não disponível"),
        )
        .otherwise(
            F.coalesce(
                F.col(
                    "TX_ASSINATURA_FLUXO"
                ),
                F.lit(
                    "Entrada: Sem entrada | "
                    "Saída: Sem saída"
                ),
            )
        ),
    )

    .withColumn(
        "TX_FAIXA_QT_TRANS_CLS",

        F.when(
            F.col(
                "FL_BASE_TRANSACIONAL_ENCONTRADA"
            ) == "N",

            F.lit("Não disponível"),
        )
        .otherwise(
            F.coalesce(
