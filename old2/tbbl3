def formatar_numero_br(
    valor,
    casas=2,
):

    if valor is None:
        return "-"

    texto = f"{float(valor):,.{casas}f}"

    return (
        texto
        .replace(",", "__MILHAR__")
        .replace(".", ",")
        .replace("__MILHAR__", ".")
    )


def formatar_inteiro_br(
    valor,
):

    if valor is None:
        return "-"

    return (
        f"{int(valor):,}"
        .replace(",", ".")
    )


def formatar_valor_tabela(
    nome_coluna,
    valor,
):

    if valor is None:
        return "-"

    if isinstance(
        valor,
        datetime,
    ):
        return valor.strftime(
            "%d/%m/%Y %H:%M:%S"
        )

    if isinstance(
        valor,
        date,
    ):
        return valor.strftime(
            "%d/%m/%Y"
        )

    if nome_coluna.startswith("PC_"):

        return (
            formatar_numero_br(
                valor,
                2,
            )
            + "%"
        )

    if nome_coluna.startswith("VL_"):

        return (
            "R$ "
            + formatar_numero_br(
                valor,
                2,
            )
        )

    if nome_coluna.startswith("QT_"):

        return formatar_inteiro_br(
            valor
        )

    if nome_coluna.startswith("CD_"):

        try:
            return str(
                int(valor)
            )
        except Exception:
            return str(valor)

    if isinstance(
        valor,
        (
            int,
            Decimal,
        ),
    ):
        return str(valor)

    if isinstance(
        valor,
        float,
    ):
        return formatar_numero_br(
            valor,
            4,
        )

    return str(valor)


