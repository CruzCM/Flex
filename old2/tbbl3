    .dataType
    .simpleString()
)


expressoes_transacoes = [
    F.col("CD_CLI")
    .cast(tipo_cd_cli)
    .alias("CD_CLI")
]


for origem, destino in (
    MAPEAMENTO_COLUNAS.items()
):

    expressoes_transacoes.append(
        F.col(origem).alias(
            destino
        )
    )


