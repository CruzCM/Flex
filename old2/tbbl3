def _formatador_inteiro_eixo(
    valor,
    _,
):

    return (
        f"{valor:,.0f}"
        .replace(",", ".")
    )


def _formatador_moeda_eixo(
    valor,
    _,
):

    if abs(valor) >= 1_000_000_000:

        return (
            "R$ "
            + formatar_numero_br(
                valor / 1_000_000_000,
                1,
            )
            + " bi"
        )

    if abs(valor) >= 1_000_000:

        return (
            "R$ "
            + formatar_numero_br(
                valor / 1_000_000,
                1,
            )
            + " mi"
        )

    if abs(valor) >= 1_000:

        return (
            "R$ "
            + formatar_numero_br(
                valor / 1_000,
                1,
            )
            + " mil"
        )

    return (
        "R$ "
        + formatar_numero_br(
            valor,
            0,
        )
    )


def publicar_grafico_barras(
    nome,
    dataframe,
    coluna_categoria,
    coluna_valor,
    titulo,
    limite=20,
    horizontal=True,
    formato="inteiro",
):

    registros = (
        dataframe
        .select(
            coluna_categoria,
            coluna_valor,
        )
        .limit(limite)
        .collect()
    )

    if not registros:

        print(
            f"⚠️ Sem dados para o gráfico: {nome}"
        )
        return

    categorias = [
        textwrap.fill(
            str(
                registro[
                    coluna_categoria
                ]
            ),
            width=28,
        )
        for registro in registros
    ]

    valores = [
        float(
            registro[
                coluna_valor
            ] or 0
        )
        for registro in registros
    ]

    figura, eixo = plt.subplots(
        figsize=(
            11,
            max(
                4.5,
                len(categorias) * 0.45,
            )
            if horizontal
            else 6,
        )
    )

    if horizontal:

        eixo.barh(
            categorias,
            valores,
        )

        eixo.invert_yaxis()

        if formato == "moeda":
            eixo.xaxis.set_major_formatter(
                FuncFormatter(
                    _formatador_moeda_eixo
                )
            )
        else:
            eixo.xaxis.set_major_formatter(
                FuncFormatter(
                    _formatador_inteiro_eixo
                )
            )

    else:

        eixo.bar(
            categorias,
            valores,
        )

        eixo.tick_params(
            axis="x",
            rotation=35,
        )

        if formato == "moeda":
            eixo.yaxis.set_major_formatter(
                FuncFormatter(
                    _formatador_moeda_eixo
                )
            )
        else:
            eixo.yaxis.set_major_formatter(
                FuncFormatter(
                    _formatador_inteiro_eixo
                )
            )

    eixo.set_title(
        titulo,
        pad=14,
        fontsize=14,
        fontweight="bold",
    )

    eixo.set_xlabel("")
    eixo.set_ylabel("")

    figura.tight_layout()

    buffer = io.BytesIO()

    figura.savefig(
        buffer,
        format="png",
        dpi=160,
        bbox_inches="tight",
    )

    plt.close(
        figura
    )

    graficos.itens[
        nome
    ] = (
        base64
        .b64encode(
            buffer.getvalue()
        )
        .decode("ascii")
    )

    print(
        f"✅ Gráfico publicado: {nome}"
    )


