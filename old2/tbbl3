%%spark

# ============================================================
# EXPORTAÇÃO DA BASE FINAL EM UM ÚNICO CSV
# ============================================================

CAMINHO_FINAL = (
    "/user/seu_usuario/"
    "ana_edu_fin_cli_persona_completa.csv"
)

CAMINHO_TEMPORARIO = (
    CAMINHO_FINAL
    + "_temporario"
)


# ============================================================
# LEITURA DA VIEW FINAL
# ============================================================

df_csv_final = spark.table(
    "VW_ANA_EDU_FIN_CLI_PERSONA_CLS"
)


# ============================================================
# GRAVAÇÃO TEMPORÁRIA
#
# coalesce(1) força a geração de um único arquivo CSV.
# ============================================================

(
    df_csv_final
    .coalesce(1)
    .write
    .mode("overwrite")
    .option("header", True)
    .option("sep", ";")
    .option("encoding", "UTF-8")
    .option("nullValue", "")
    .option("dateFormat", "dd/MM/yyyy")
    .option("timestampFormat", "dd/MM/yyyy HH:mm:ss")
    .csv(
        CAMINHO_TEMPORARIO
    )
)


# ============================================================
# RENOMEIA O ARQUIVO PART PARA O NOME FINAL
# ============================================================

jvm = spark._jvm

configuracao_hadoop = (
    spark
    ._jsc
    .hadoopConfiguration()
)

sistema_arquivos = (
    jvm
    .org
    .apache
    .hadoop
    .fs
    .FileSystem
    .get(
        configuracao_hadoop
    )
)

caminho_temporario_hdfs = (
    jvm
    .org
    .apache
    .hadoop
    .fs
    .Path(
        CAMINHO_TEMPORARIO
    )
)

caminho_final_hdfs = (
    jvm
    .org
    .apache
    .hadoop
    .fs
    .Path(
        CAMINHO_FINAL
    )
)


arquivos_part = [
    arquivo.getPath()
    for arquivo
    in sistema_arquivos.listStatus(
        caminho_temporario_hdfs
    )
    if arquivo
    .getPath()
    .getName()
    .startswith("part-")
]


if len(arquivos_part) != 1:

    raise RuntimeError(
        "Era esperado exatamente um arquivo part, "
        f"mas foram encontrados {len(arquivos_part)}."
    )


if sistema_arquivos.exists(
    caminho_final_hdfs
):

    sistema_arquivos.delete(
        caminho_final_hdfs,
        True,
    )


renomeado = sistema_arquivos.rename(
    arquivos_part[0],
    caminho_final_hdfs,
)


if not renomeado:

    raise RuntimeError(
        "Não foi possível renomear "
        "o arquivo CSV final."
    )


sistema_arquivos.delete(
    caminho_temporario_hdfs,
    True,
)


# ============================================================
# RESULTADO
# ============================================================

print(
    "✅ CSV único criado com sucesso"
)

print(
    f"📁 Caminho: {CAMINHO_FINAL}"
)

print(
    f"📊 Colunas: {len(df_csv_final.columns)}"
)


