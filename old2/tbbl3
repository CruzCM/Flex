%%spark

# ============================================================
# BASE FINAL DE PERSONAS
# ============================================================

from functools import reduce

from pyspark.sql import functions as F


# ============================================================
# CONFIGURAÇÃO
# ============================================================

TABELA_ORIGEM = (
    "sbx_t2i2016."
    "v1_ana_edu_fin_cli"
)

COLUNAS_PONTUACAO = [
    "NR_PONT_CONC_ESS",
    "NR_PONT_CONC_FLEX",
    "NR_PONT_CONC_RES",
    "NR_PONT_CONC_CRED",
]


# ============================================================
# LEITURA DA TABELA ORIGINAL
# ============================================================

df_origem = spark.table(
    TABELA_ORIGEM
)

COLUNAS_ORIGINAIS = (
    df_origem.columns
)


# ============================================================
# VALIDAÇÃO DAS COLUNAS OBRIGATÓRIAS
# ============================================================

COLUNAS_OBRIGATORIAS = [
    "CD_CLI",
    "NR_PONT_CONC_GEN",
    "NR_PONT_CONC_ESS",
    "NR_PONT_CONC_FLEX",
    "NR_PONT_CONC_RES",
    "NR_PONT_CONC_CRED",
]


colunas_ausentes = [
    coluna
    for coluna in COLUNAS_OBRIGATORIAS
    if coluna not in df_origem.columns
]


if colunas_ausentes:

    raise ValueError(
        "Colunas obrigatórias não encontradas: "
        + ", ".join(colunas_ausentes)
    )


# ============================================================
# FUNÇÕES AUXILIARES
# ============================================================

def classificar_pontuacao(
    coluna,
    texto_ponto_0,
    texto_ponto_1,
    texto_ponto_2,
):

    return (
        F.when(
            F.col(coluna) == 0,
            F.lit(texto_ponto_0),
        )
        .when(
            F.col(coluna) == 1,
            F.lit(texto_ponto_1),
        )
        .when(
            F.col(coluna) == 2,
            F.lit(texto_ponto_2),
        )
        .otherwise(
            F.lit("Não classificado")
        )
    )


def contar_dimensoes_com_ponto(
    ponto,
):

    expressoes = [
        F.when(
            F.col(coluna) == ponto,
            F.lit(1),
        ).otherwise(
            F.lit(0)
        )
        for coluna in COLUNAS_PONTUACAO
    ]

    return reduce(
        lambda acumulado, expressao:
            acumulado + expressao,
        expressoes,
        F.lit(0),
    )


# ============================================================
# VALIDAÇÃO DA PONTUAÇÃO
# ============================================================

CONDICAO_PONTUACAO_VALIDA = reduce(
    lambda condicao_atual, nova_condicao:
        condicao_atual & nova_condicao,

    [
        F.col(coluna).isin(
            0,
            1,
            2,
        )
        for coluna in COLUNAS_PONTUACAO
    ],
)


CONDICAO_CATEGORIZACAO_VALIDA = (
    F.col("NR_PONT_CONC_GEN")
    .isin(
        0,
        99,
    )
)


# ============================================================
# CONSTRUÇÃO DO DATAFRAME ENRIQUECIDO
# ============================================================

df_persona_enriquecido = (
    df_origem

    # ========================================================
    # ARRAY ORIGINAL DAS QUATRO PONTUAÇÕES
    # ========================================================

    .withColumn(
        "AR_PONT_PERSONA",

        F.array(
            F.col(
                "NR_PONT_CONC_ESS"
            ).cast("int"),

            F.col(
                "NR_PONT_CONC_FLEX"
            ).cast("int"),

            F.col(
                "NR_PONT_CONC_RES"
            ).cast("int"),

            F.col(
                "NR_PONT_CONC_CRED"
            ).cast("int"),
        ),
    )

    # ========================================================
    # VALIDADE DA PERSONA
    # ========================================================

    .withColumn(
        "FL_PONT_PERSONA_VALIDA",

        F.when(
            CONDICAO_PONTUACAO_VALIDA,
            F.lit("S"),
        ).otherwise(
            F.lit("N")
        ),
    )

    # ========================================================
    # VARIÁVEIS TEXTUAIS INDIVIDUAIS
    # ========================================================

    .withColumn(
        "TX_CONC_ESS",

        classificar_pontuacao(
            coluna="NR_PONT_CONC_ESS",
            texto_ponto_0="Essencial baixo",
            texto_ponto_1="Essencial médio",
            texto_ponto_2="Essencial alto",
        ),
    )

    .withColumn(
        "TX_CONC_FLEX",

        classificar_pontuacao(
            coluna="NR_PONT_CONC_FLEX",
            texto_ponto_0="Flexível baixo",
            texto_ponto_1="Flexível médio",
            texto_ponto_2="Flexível alto",
        ),
    )

    .withColumn(
        "TX_CONC_RES",

        classificar_pontuacao(
            coluna="NR_PONT_CONC_RES",
            texto_ponto_0="Reserva alta",
            texto_ponto_1="Reserva média",
            texto_ponto_2="Reserva baixa",
        ),
    )

    .withColumn(
        "TX_CONC_CRED",

        classificar_pontuacao(
            coluna="NR_PONT_CONC_CRED",
            texto_ponto_0="Crédito baixo",
            texto_ponto_1="Crédito médio",
            texto_ponto_2="Crédito alto",
        ),
    )

    # ========================================================
    # QUALIDADE DA CATEGORIZAÇÃO
    # ========================================================

    .withColumn(
        "TX_CATEGORIZACAO",

        F.when(
            F.col("NR_PONT_CONC_GEN") == 0,
            F.lit("Categorização alta"),
        )
        .when(
            F.col("NR_PONT_CONC_GEN") == 99,
            F.lit("Categorização baixa"),
        )
        .otherwise(
            F.lit(
                "Categorização não definida"
            )
        ),
    )

    .withColumn(
        "FL_CATEGORIZACAO_VALIDA",

        F.when(
            CONDICAO_CATEGORIZACAO_VALIDA,
            F.lit("S"),
        ).otherwise(
            F.lit("N")
        ),
    )

    .withColumn(
        "FL_CATEGORIZACAO_ALTA",

        F.when(
            F.col("NR_PONT_CONC_GEN") == 0,
            F.lit("S"),
        )
        .when(
            F.col("NR_PONT_CONC_GEN") == 99,
            F.lit("N"),
        ),
    )

    # ========================================================
    # SOMA CONSOLIDADA DE 0 A 8
    # ========================================================

    .withColumn(
        "NR_PONT_PERSONA",

        F.when(
            CONDICAO_PONTUACAO_VALIDA,

            F.col("NR_PONT_CONC_ESS")
            + F.col("NR_PONT_CONC_FLEX")
            + F.col("NR_PONT_CONC_RES")
            + F.col("NR_PONT_CONC_CRED"),
        ),
    )

    # ========================================================
    # FAIXA DA PONTUAÇÃO
    # ========================================================

    .withColumn(
        "TX_FAIXA_PONT_PERSONA",

        F.when(
            F.col("NR_PONT_PERSONA")
            .between(0, 1),

            F.lit("0 a 1"),
        )
        .when(
            F.col("NR_PONT_PERSONA")
            .between(2, 3),

            F.lit("2 a 3"),
        )
        .when(
            F.col("NR_PONT_PERSONA")
            .between(4, 5),

            F.lit("4 a 5"),
        )
        .when(
            F.col("NR_PONT_PERSONA")
            .between(6, 7),

            F.lit("6 a 7"),
        )
        .when(
            F.col("NR_PONT_PERSONA") == 8,

            F.lit("8"),
        )
        .otherwise(
            F.lit("Não classificado")
        ),
    )

    # ========================================================
    # CÓDIGO ORDENADO DA PERSONA
    # ========================================================

    .withColumn(
        "CD_PERSONA",

        F.when(
            F.col("NR_PONT_PERSONA")
            .between(0, 1),
            F.lit(1),
        )
        .when(
            F.col("NR_PONT_PERSONA")
            .between(2, 3),
            F.lit(2),
        )
        .when(
            F.col("NR_PONT_PERSONA")
            .between(4, 5),
            F.lit(3),
        )
        .when(
            F.col("NR_PONT_PERSONA")
            .between(6, 7),
            F.lit(4),
        )
        .when(
            F.col("NR_PONT_PERSONA") == 8,
            F.lit(5),
        ),
    )

    # ========================================================
    # PERSONA EXECUTIVA
    # ========================================================

    .withColumn(
        "NM_PERSONA",

        F.when(
            F.col("NR_PONT_PERSONA")
            .between(0, 1),

            F.lit("Planejador"),
        )
        .when(
            F.col("NR_PONT_PERSONA")
            .between(2, 3),

            F.lit("Em atenção"),
        )
        .when(
            F.col("NR_PONT_PERSONA")
            .between(4, 5),

            F.lit("Pressionado"),
        )
        .when(
            F.col("NR_PONT_PERSONA")
            .between(6, 7),

            F.lit("Vulnerável"),
        )
        .when(
            F.col("NR_PONT_PERSONA") == 8,

            F.lit("Crítico"),
        )
        .otherwise(
            F.lit("Não classificado")
        ),
    )

    # ========================================================
    # DESCRIÇÃO EXECUTIVA DA PERSONA
    # ========================================================

    .withColumn(
        "TX_DESC_PERSONA",

        F.when(
            F.col("NM_PERSONA") == "Planejador",

            F.lit(
                "Baixa criticidade nas quatro dimensões"
            ),
        )
        .when(
            F.col("NM_PERSONA") == "Em atenção",

            F.lit(
                "Possui pontos que requerem acompanhamento"
            ),
        )
        .when(
            F.col("NM_PERSONA") == "Pressionado",

            F.lit(
                "Apresenta desequilíbrios financeiros relevantes"
            ),
        )
        .when(
            F.col("NM_PERSONA") == "Vulnerável",

            F.lit(
                "Concentra criticidade em várias dimensões"
            ),
        )
        .when(
            F.col("NM_PERSONA") == "Crítico",

            F.lit(
                "Apresenta criticidade máxima nas quatro dimensões"
            ),
        )
        .otherwise(
            F.lit("Não classificado")
        ),
    )

    # ========================================================
    # QUANTIDADE DE DIMENSÕES EM CADA NÍVEL
    # ========================================================

    .withColumn(
        "QT_DIM_PONTO_0",

        F.when(
            CONDICAO_PONTUACAO_VALIDA,
            contar_dimensoes_com_ponto(0),
        ),
    )

    .withColumn(
        "QT_DIM_PONTO_1",

        F.when(
            CONDICAO_PONTUACAO_VALIDA,
            contar_dimensoes_com_ponto(1),
        ),
    )

    .withColumn(
        "QT_DIM_PONTO_2",

        F.when(
            CONDICAO_PONTUACAO_VALIDA,
            contar_dimensoes_com_ponto(2),
        ),
    )

    # ========================================================
    # COMPOSIÇÃO RESUMIDA DOS PONTOS
    # ========================================================

    .withColumn(
        "TX_COMPOSICAO_PONTOS",

        F.when(
            CONDICAO_PONTUACAO_VALIDA,

            F.format_string(
                "%d dimensão(ões) em 0 | "
                "%d dimensão(ões) em 1 | "
                "%d dimensão(ões) em 2",

                F.col("QT_DIM_PONTO_0"),
                F.col("QT_DIM_PONTO_1"),
                F.col("QT_DIM_PONTO_2"),
            ),
        )
        .otherwise(
            F.lit("Não classificado")
        ),
    )

    # ========================================================
    # MAIOR E MENOR PONTUAÇÃO INDIVIDUAL
    # ========================================================

    .withColumn(
        "NR_PONT_MAX_DIMENSAO",

        F.when(
            CONDICAO_PONTUACAO_VALIDA,

            F.greatest(
                F.col("NR_PONT_CONC_ESS"),
                F.col("NR_PONT_CONC_FLEX"),
                F.col("NR_PONT_CONC_RES"),
                F.col("NR_PONT_CONC_CRED"),
            ),
        ),
    )

    .withColumn(
        "NR_PONT_MIN_DIMENSAO",

        F.when(
            CONDICAO_PONTUACAO_VALIDA,

            F.least(
                F.col("NR_PONT_CONC_ESS"),
                F.col("NR_PONT_CONC_FLEX"),
                F.col("NR_PONT_CONC_RES"),
                F.col("NR_PONT_CONC_CRED"),
            ),
        ),
    )

    # ========================================================
    # TEMAS COM MAIOR PONTUAÇÃO
    # ========================================================

    .withColumn(
        "TX_TEMAS_PRIORITARIOS",

        F.when(
            ~CONDICAO_PONTUACAO_VALIDA,

            F.lit("Não classificado"),
        )
        .when(
            F.col("NR_PONT_MAX_DIMENSAO") == 0,

            F.lit("Nenhum tema prioritário"),
        )
        .otherwise(
            F.concat_ws(
                " | ",

                F.when(
                    F.col("NR_PONT_CONC_ESS")
                    == F.col("NR_PONT_MAX_DIMENSAO"),

                    F.lit("Essencial"),
                ),

                F.when(
                    F.col("NR_PONT_CONC_FLEX")
                    == F.col("NR_PONT_MAX_DIMENSAO"),

                    F.lit("Flexível"),
                ),

                F.when(
                    F.col("NR_PONT_CONC_RES")
                    == F.col("NR_PONT_MAX_DIMENSAO"),

                    F.lit("Reserva"),
                ),

                F.when(
                    F.col("NR_PONT_CONC_CRED")
                    == F.col("NR_PONT_MAX_DIMENSAO"),

                    F.lit("Crédito"),
                ),
            )
        ),
    )

    # ========================================================
    # CÓDIGO TEXTUAL DA ASSINATURA
    # ========================================================

    .withColumn(
        "CD_ASSINATURA_PERSONA",

        F.when(
            CONDICAO_PONTUACAO_VALIDA,

            F.concat(
                F.lit("E"),
                F.col(
                    "NR_PONT_CONC_ESS"
                ).cast("string"),

                F.lit("-F"),
                F.col(
                    "NR_PONT_CONC_FLEX"
                ).cast("string"),

                F.lit("-R"),
                F.col(
                    "NR_PONT_CONC_RES"
                ).cast("string"),

                F.lit("-C"),
                F.col(
                    "NR_PONT_CONC_CRED"
                ).cast("string"),
            ),
        )
        .otherwise(
            F.lit("NÃO_CLASSIFICADO")
        ),
    )

    # ========================================================
    # ID NUMÉRICO ÚNICO DAS 81 COMBINAÇÕES
    #
    # ESS  * 27
    # FLEX *  9
    # RES  *  3
    # CRED *  1
    #
    # Resultado: 1 até 81
    # ========================================================

    .withColumn(
        "NR_ID_ASSINATURA_PERSONA",

        F.when(
            CONDICAO_PONTUACAO_VALIDA,

            (
                F.col("NR_PONT_CONC_ESS") * 27
                + F.col("NR_PONT_CONC_FLEX") * 9
                + F.col("NR_PONT_CONC_RES") * 3
                + F.col("NR_PONT_CONC_CRED")
                + 1
            ).cast("int"),
        ),
    )

    # ========================================================
    # ASSINATURA COMPORTAMENTAL COMPLETA
    # ========================================================

    .withColumn(
        "TX_ASSINATURA_COMPORTAMENTAL",

        F.when(
            CONDICAO_PONTUACAO_VALIDA,

            F.concat_ws(
                " | ",
                F.col("TX_CONC_ESS"),
                F.col("TX_CONC_FLEX"),
                F.col("TX_CONC_RES"),
                F.col("TX_CONC_CRED"),
            ),
        )
        .otherwise(
            F.lit("Não classificado")
        ),
    )

    # ========================================================
    # PERSONA + CATEGORIZAÇÃO PARA TODOS OS CLIENTES
    # ========================================================

    .withColumn(
        "NM_PERSONA_CATEGORIZACAO",

        F.when(
            CONDICAO_PONTUACAO_VALIDA,

            F.concat_ws(
                " | ",
                F.col("NM_PERSONA"),
                F.col("TX_CATEGORIZACAO"),
            ),
        )
        .otherwise(
            F.lit("Não classificado")
        ),
    )

    # ========================================================
    # PERSONA FINAL
    #
    # Somente a pontuação 8 é subdividida pela categorização.
    # As demais pontuações mantêm a persona executiva.
    # ========================================================

    .withColumn(
        "NM_PERSONA_FINAL",

        F.when(
            ~CONDICAO_PONTUACAO_VALIDA,

            F.lit("Não classificado"),
        )
        .when(
            (
                F.col("NR_PONT_PERSONA") == 8
            )
            & (
                F.col("NR_PONT_CONC_GEN") == 0
            ),

            F.lit("Crítico categorizado"),
        )
        .when(
            (
                F.col("NR_PONT_PERSONA") == 8
            )
            & (
                F.col("NR_PONT_CONC_GEN") == 99
            ),

            F.lit(
                "Crítico com baixa categorização"
            ),
        )
        .when(
            F.col("NR_PONT_PERSONA") == 8,

            F.lit(
                "Crítico com categorização não definida"
            ),
        )
        .otherwise(
            F.col("NM_PERSONA")
        ),
    )

    # ========================================================
    # FLAGS EXECUTIVAS
    # ========================================================

    .withColumn(
        "FL_PERSONA_CRITICA",

        F.when(
            F.col("NR_PONT_PERSONA") == 8,
            F.lit("S"),
        )
        .when(
            F.col("NR_PONT_PERSONA").isNotNull(),
            F.lit("N"),
        ),
    )

    .withColumn(
        "FL_PERSONA_VULNERAVEL_OU_CRITICA",

        F.when(
            F.col("NR_PONT_PERSONA")
            .between(6, 8),

            F.lit("S"),
        )
        .when(
            F.col("NR_PONT_PERSONA").isNotNull(),
            F.lit("N"),
        ),
    )
)


# ============================================================
# ORDEM FINAL DAS COLUNAS DERIVADAS
# ============================================================

COLUNAS_DERIVADAS_PERSONA = [
    "AR_PONT_PERSONA",

    "FL_PONT_PERSONA_VALIDA",

    "TX_CONC_ESS",
    "TX_CONC_FLEX",
    "TX_CONC_RES",
    "TX_CONC_CRED",

    "TX_CATEGORIZACAO",
    "FL_CATEGORIZACAO_VALIDA",
    "FL_CATEGORIZACAO_ALTA",

    "NR_PONT_PERSONA",
    "TX_FAIXA_PONT_PERSONA",

    "CD_PERSONA",
    "NM_PERSONA",
    "TX_DESC_PERSONA",

    "QT_DIM_PONTO_0",
    "QT_DIM_PONTO_1",
    "QT_DIM_PONTO_2",
    "TX_COMPOSICAO_PONTOS",

    "NR_PONT_MAX_DIMENSAO",
    "NR_PONT_MIN_DIMENSAO",
    "TX_TEMAS_PRIORITARIOS",

    "CD_ASSINATURA_PERSONA",
    "NR_ID_ASSINATURA_PERSONA",
    "TX_ASSINATURA_COMPORTAMENTAL",

    "NM_PERSONA_CATEGORIZACAO",
    "NM_PERSONA_FINAL",

    "FL_PERSONA_CRITICA",
    "FL_PERSONA_VULNERAVEL_OU_CRITICA",
]


# ============================================================
# DATAFRAME FINAL
# ============================================================

df_persona_final = (
    df_persona_enriquecido
    .select(
        *COLUNAS_ORIGINAIS,
        *COLUNAS_DERIVADAS_PERSONA,
    )
)


# ============================================================
