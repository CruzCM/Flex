    ):

        tipo = (
            campo.dataType
            .simpleString()
        )

        df_persona_classificacao = (
            df_persona_classificacao

            .withColumn(
                coluna,

                F.when(
                    F.col(
                        "FL_BASE_TRANSACIONAL_ENCONTRADA"
                    ) == "S",

                    F.coalesce(
                        F.col(coluna),
                        F.lit(0).cast(
                            tipo
                        ),
                    ),
                )
                .otherwise(
                    F.lit(None).cast(
                        tipo
                    )
                ),
            )
        )


