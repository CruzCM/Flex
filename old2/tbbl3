    coluna
    for coluna
    in df_classificacao_cliente.columns
    if coluna != "CD_CLI"
]


# ============================================================
# 10. JUNÇÃO COM A VIEW DE PERSONAS
# ============================================================

df_persona_classificacao = (
    df_persona_origem.alias("p")

    .join(
        df_classificacao_cliente.alias("c"),

        F.col("p.CD_CLI")
        ==
        F.col("c.CD_CLI"),

        "left",
    )

    .select(
        *[
            F.col(
                f"p.{coluna}"
            ).alias(
                coluna
            )
            for coluna
            in COLUNAS_PERSONA_ORIGINAIS
        ],

        F.col(
            "c.CD_CLI"
        ).alias(
            "_CD_CLI_CLASSIFICACAO"
        ),

        *[
            F.col(
                f"c.{coluna}"
            ).alias(
                coluna
            )
            for coluna
            in COLUNAS_CLASSIFICACAO_BASE
        ],
    )

    .withColumn(
        "FL_BASE_TRANSACIONAL_ENCONTRADA",

        F.when(
            F.col(
                "_CD_CLI_CLASSIFICACAO"
            ).isNotNull(),

            F.lit("S"),
        )
        .otherwise(
            F.lit("N")
        ),
    )

    .drop(
        "_CD_CLI_CLASSIFICACAO"
    )
)


