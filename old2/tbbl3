# 26. VALIDAÇÃO DO ENRIQUECIMENTO
# ============================================================

tb_validacao_enriquecimento = (
    df_persona_classificacao_final

    .agg(
        F.count("*").alias(
            "QT_LINHAS"
        ),

        F.countDistinct(
            "CD_CLI"
        ).alias(
            "QT_CLIENTES"
        ),

        F.sum(
            F.when(
                F.col(
                    "FL_BASE_TRANSACIONAL_ENCONTRADA"
                ) == "S",
                1,
            ).otherwise(0)
        ).alias(
            "QT_LINHAS_COM_BASE_TRANSACIONAL"
        ),

        F.sum(
            F.when(
                F.col(
                    "FL_BASE_TRANSACIONAL_ENCONTRADA"
                ) == "N",
                1,
            ).otherwise(0)
        ).alias(
            "QT_LINHAS_SEM_BASE_TRANSACIONAL"
        ),

        F.sum(
            F.when(
                F.col(
                    "FL_RECON_GERAL_CLS"
                ) == "S",
                1,
            ).otherwise(0)
        ).alias(
            "QT_LINHAS_CONCILIADAS"
        ),

        F.sum(
            F.when(
                F.col(
                    "FL_RECON_GERAL_CLS"
                ) == "N",
                1,
            ).otherwise(0)
        ).alias(
            "QT_LINHAS_COM_DIFERENCA"
        ),

        F.countDistinct(
            "CD_ASSINATURA_FLUXO"
        ).alias(
            "QT_ASSINATURAS_FLUXO"
        ),
    )

    .withColumn(
        "PC_LINHAS_COM_BASE_TRANSACIONAL",

        F.round(
            F.col(
                "QT_LINHAS_COM_BASE_TRANSACIONAL"
            )
            /
            F.col(
                "QT_LINHAS"
            )
            * 100,
            4,
        ),
    )

    .withColumn(
        "PC_LINHAS_CONCILIADAS",

        F.when(
            F.col(
                "QT_LINHAS_COM_BASE_TRANSACIONAL"
            ) > 0,

            F.round(
                F.col(
                    "QT_LINHAS_CONCILIADAS"
                )
                /
                F.col(
                    "QT_LINHAS_COM_BASE_TRANSACIONAL"
                )
                * 100,
                4,
            ),
        ),
    )
)


tb_validacao_enriquecimento \
    .createOrReplaceTempView(
        VIEW_VALIDACAO
    )


