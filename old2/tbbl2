)


def exibir_tabela_html_spark(
    nomes,
    sessao=None,
    mostrar_cabecalho=False,
):

    """
    Exibe uma ou várias tabelas HTML
    publicadas no ambiente Spark.
    """

    if sessao is None:

        if "gerenciador_spark" not in globals():

            raise NameError(
                "A variável 'gerenciador_spark' "
                "não está definida no notebook local."
            )

        sessao = gerenciador_spark.spark

    if isinstance(
        nomes,
        str,
    ):
        nomes = [nomes]

    catalogo = sessao.get_from_spark(
        "tabelas_html.itens"
    )

    if catalogo is None:

        raise RuntimeError(
            "O Spark retornou None para "
            "'tabelas_html.itens'."
        )

    if not catalogo:

        raise RuntimeError(
            "O catálogo de tabelas HTML está vazio. "
            "Execute novamente o código Spark."
        )

    resultados = {}

    for i, nome in enumerate(
        nomes,
        start=1,
    ):

        if mostrar_cabecalho:

            print("\n" + "=" * 100)
            print(f"📋 {i:02d} | {nome}")
            print("=" * 100)

        if nome not in catalogo:

            print(
                f"⚠️ Tabela não encontrada: {nome}"
            )

            print(
                "Disponíveis:",
                sorted(catalogo.keys()),
            )

            continue

        conteudo_html = catalogo[nome]

        if conteudo_html is None:

            print(
                f"⚠️ Conteúdo vazio: {nome}"
            )

            continue

        conteudo_html = str(
            conteudo_html
        )

        if not conteudo_html.strip():

            print(
                f"⚠️ Conteúdo HTML vazio: {nome}"
            )

            continue

        resultados[nome] = conteudo_html

        display(
            HTML(
                conteudo_html
            )
        )

    return resultados


def listar_tabelas_html_locais(
    sessao=None,
):

    if sessao is None:

        if "gerenciador_spark" not in globals():

            raise NameError(
                "A variável 'gerenciador_spark' "
                "não está definida."
            )

        sessao = gerenciador_spark.spark

    catalogo = sessao.get_from_spark(
        "tabelas_html.itens"
    )

    if not catalogo:

        print(
            "⚠️ Nenhuma tabela HTML disponível"
        )

        return []

    nomes = sorted(
        catalogo.keys()
    )

    print("\n" + "=" * 100)
    print("TABELAS HTML DISPONÍVEIS")
    print("=" * 100)

    for i, nome in enumerate(
        nomes,
        start=1,
    ):

        print(
            f"{i:02d} -> {nome}"
        )

    return nomes


def obter_tabela_html_spark(
    nome,
    sessao=None,
):

    if sessao is None:

        if "gerenciador_spark" not in globals():

            raise NameError(
                "A variável 'gerenciador_spark' "
                "não está definida."
            )

        sessao = gerenciador_spark.spark

    catalogo = sessao.get_from_spark(
        "tabelas_html.itens"
    )

    if not catalogo:

        raise RuntimeError(
            "Nenhuma tabela HTML disponível."
        )

    if nome not in catalogo:

        raise KeyError(
            f"Tabela não encontrada: {nome}"
        )

    return str(
        catalogo[nome]
    )
