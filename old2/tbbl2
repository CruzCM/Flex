def formatar_inteiro_br(
    valor,
):

    if valor is None:
        return "-"

    return (
        f"{int(valor):,}"
        .replace(",", ".")
    )


def formatar_decimal_br(
    valor,
    casas=2,
):

    if valor is None:
        return "-"

    texto = (
        f"{float(valor):,.{casas}f}"
    )

    return (
        texto
        .replace(",", "__MILHAR__")
        .replace(".", ",")
        .replace("__MILHAR__", ".")
    )


def formatar_percentual_br(
    valor,
    casas=2,
):

    if valor is None:
        return "-"

    return (
        formatar_decimal_br(
            valor,
            casas,
        )
        + "%"
    )


def calcular_percentual(
    quantidade,
    total,
):

    if not total:
        return 0.0

    return round(
        quantidade
        / total
        * 100,
        2,
    )


# ============================================================
