# ============================================================
# REPOSITÓRIO DE TABELAS HTML
# ============================================================

class TabelasHTML:

    def __init__(self):
        self.itens = {}

    def publicar(
        self,
        nome,
        html,
    ):

        if not isinstance(html, str):
            raise TypeError(
                "O conteúdo da tabela deve ser uma string HTML."
            )

        if not html.strip():
            raise ValueError(
                "O conteúdo HTML está vazio."
            )

        self.itens[nome] = html

        print(
            f"✅ Tabela HTML publicada: {nome}"
        )

        print(
            f"📦 Tamanho: {len(html):,} caracteres"
        )

    def remover(
        self,
        nome,
    ):

        if nome not in self.itens:
            print(
                f"⚠️ Tabela não encontrada: {nome}"
            )
            return

        del self.itens[nome]

        print(
            f"🗑️ Tabela removida: {nome}"
        )

    def listar(self):

        nomes = sorted(
            self.itens.keys()
        )

        print("\n" + "=" * 100)
        print("TABELAS HTML")
        print("=" * 100)

        if not nomes:
            print(
                "⚠️ Nenhuma tabela publicada"
            )
            return

        for i, nome in enumerate(
            nomes,
            start=1,
        ):
            print(
                f"{i:02d} -> {nome}"
            )

        print("\n" + "=" * 100)
        print("COMANDO PARA O NOTEBOOK LOCAL")
        print("=" * 100)

        print(
            f"exibir_tabela_html_spark({nomes!r})"
        )

    def limpar(self):

        quantidade = len(
            self.itens
        )

        self.itens.clear()

        print(
            f"🗑️ {quantidade} tabela(s) removida(s)"
        )


# ============================================================
# INSTÂNCIA GLOBAL
# ============================================================

if "tabelas_html" not in globals():

    tabelas_html = TabelasHTML()

    print(
        "🚀 Repositório de tabelas HTML criado"
    )


# ============================================================
# FUNÇÕES DE ATALHO
# ============================================================

def publicar_tabela_html(
    nome,
    html,
):

    tabelas_html.publicar(
        nome=nome,
        html=html,
    )


def listar_tabelas_html_spark():

    tabelas_html.listar()


def remover_tabela_html_spark(
    nome,
):

    tabelas_html.remover(
        nome
    )


def limpar_tabelas_html_spark():

    tabelas_html.limpar()






