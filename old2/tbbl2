        F.max(
            "DT_EXEA"
        ).alias(
            "DT_EXEA_MAX"
        )
    )
    .first()[
        "DT_EXEA_MAX"
    ]
)


df = (
    df_origem
    .filter(
        F.col("DT_EXEA")
        == F.lit(dt_exea_max)
    )
    .dropDuplicates([
        "CD_CLI"
    ])
    .cache()
)


# ============================================================
# AGREGAÇÃO DOS INDICADORES
# ============================================================

resumo = (
    df
    .agg(
        F.count(
            "*"
        ).alias(
            "TOTAL_CLIENTES"
        ),

        F.min(
            "DT_REF_INI"
        ).alias(
            "DT_REF_INI"
        ),

        F.max(
            "DT_REF_FIM"
        ).alias(
            "DT_REF_FIM"
        ),

        F.sum(
            F.when(
                F.upper(
                    F.trim(
                        F.col("NM_PRFL")
                    )
                )
                == "A CLASSIFICAR",
                1,
            ).otherwise(0)
        ).alias(
            "PRFL_A_CLASSIFICAR"
        ),

        F.sum(
            F.when(
                F.upper(
                    F.trim(
                        F.col(
                            "NM_MAC_PRFL_CLI"
                        )
                    )
                )
                == "A CLASSIFICAR",
                1,
            ).otherwise(0)
        ).alias(
            "MACRO_A_CLASSIFICAR"
        ),

        F.sum(
            F.when(
                F.upper(
                    F.trim(
                        F.col(
                            "FL_TEM_MOV_AGRO"
                        )
                    )
                )
                == "S",
                1,
            ).otherwise(0)
        ).alias(
            "AGRO_SIM"
        ),

        F.sum(
            F.when(
                F.col(
                    "QT_TRANS_ENT"
                )
                == 0,
                1,
            ).otherwise(0)
        ).alias(
            "ENTRADA_ZERO"
        ),

        F.sum(
            F.when(
                F.col(
                    "QT_TRANS_SAI"
                )
                == 0,
                1,
            ).otherwise(0)
        ).alias(
            "SAIDA_ZERO"
        ),

        F.sum(
            F.when(
                F.upper(
                    F.trim(
                        F.col(
                            "FL_PARTICIPA_RADAR"
                        )
                    )
                )
                == "S",
