from pyspark.sql import types as T
from pyspark.sql import functions as F

# ============================================================
# OBJETIVO DO MOCK
# ============================================================
#
# Demonstrar estados de recomendação e de versão:
#
# CD_EST_RCM:
# 1 = EM_PREPARAÇÃO
# 2 = AGUARDANDO_VIGÊNCIA
# 3 = VIGENTE
# 4 = EXPIRADA
