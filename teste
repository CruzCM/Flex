        F.col("mfin.PERFIL").alias("PERFIL"),
        F.col("IDADE"),
        F.col("pf.COD_SEXO").alias("COD_SEXO"),
        F.col("GRAU_INST"),
        F.col("mfin.VL_REND").alias("VL_REND"),
