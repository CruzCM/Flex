hoje = ler_variavel_ambiente_spark("HOJE")

tabela_destino = f"{hive_database}.pbco_plt_fnc_ctgr"

# Parâmetros JDBC definidos com base nos diagnósticos enviados.
fetchsize_db2 = 10_000
num_particoes_db2 = 16
query_timeout_db2 = 3600
num_particoes_escrita_hive = 10

# Lista de DataFrames persistidos nesta execução.
# Nunca use spark.catalog.clearCache(), pois ele pode apagar caches de outras rotinas.
persistidos = []


def materializar(df, nome):
    """Persiste em disco e força uma única leitura/execução da fase."""
    df_persistido = df.persist(StorageLevel.DISK_ONLY)
    quantidade = df_persistido.count()
    persistidos.append((nome, df_persistido))
    logger.info(f"{nome}: materializado com {quantidade:,} linhas.")
    return df_persistido, quantidade


def liberar(df, nome):
    """Libera um cache que não será mais necessário nas fases seguintes."""
    df.unpersist(blocking=False)

    for indice, (nome_persistido, df_persistido) in enumerate(persistidos):
        if df_persistido is df:
            persistidos.pop(indice)
            break

    logger.info(f"{nome}: cache liberado.")


def liberar_todos_persistidos():
    """Libera somente os caches criados por este ETL."""
    for nome, df in list(persistidos):
        df.unpersist(blocking=False)
        logger.info(f"{nome}: cache liberado no encerramento.")

    persistidos.clear()


