# COMMAND ----------
# %%spark
# BLOCO 6 — Contrato da tabela final e transformação final.
# Objetivo: gerar as colunas finais mantendo as mesmas regras, nomes e ordem do destino.
# spark.table é usado aqui somente para ler o schema da tabela Hive de destino.

schema_destino = spark.table(tabela_destino).schema
colunas_destino = [campo.name for campo in schema_destino.fields]

# A ordenação abaixo é exatamente a do código original.
# Empates em SOMA e CD_CLI continuam tendo a mesma regra original.
janela_chave = Window.partitionBy("DT_REF").orderBy("SOMA", "CD_CLI")

df_final = (
    df_publico
    .where(F.col("CD_CLI").isNotNull())
    .withColumn("CD_CT_TITR", F.col("CD_CT_TITR").cast("integer"))
    .withColumn("DT_REF", F.to_date("DT_REF", "M/yyyy"))
    .withColumn("ROW", F.row_number().over(janela_chave))
    .where(F.col("DT_REF").isNotNull())
    .withColumn(
        "CD_CHV_REG",
        F.sha1(F.concat("CD_CLI", "DT_REF", "SOMA", "ROW")),
    )
    .drop("ROW")
    .withColumn("AA_MMM", F.date_format("DT_REF", "yyyyMM"))
    .withColumnRenamed("CD_PERFIL", "CD_PRFL")
    .withColumnRenamed("PERFIL", "TX_PRFL")
    .withColumnRenamed("IDADE", "NR_IDD_CLI")
    .withColumnRenamed("COD_SEXO", "CD_SEXO")
    .withColumnRenamed("GRAU_INST", "TX_DCR_NVL_ITC")
    .withColumnRenamed("VL_REND", "VL_REN")
    .withColumnRenamed("ETDO_CIVIL", "TX_EST_CVL")
    .withColumnRenamed("PRD", "TX_DCR_PRD")
    .withColumnRenamed("TX_DCR_CTGR_TRAN", "TX_DCR_CTGR_TRNS")
    .withColumnRenamed("LANCAMENTO", "TX_ANOT_CTGR_TRNS")
    .withColumnRenamed("TP_LANCAMENTO", "TX_TIP_TRNS")
    .withColumnRenamed("MEDIA", "VL_MED_TRNS")
    .withColumnRenamed("SOMA", "VL_TTL_TRNS")
    .withColumnRenamed("QTD", "QT_TRNS")
    .withColumnRenamed("CD_CTGR_TRAN_OGNL", "CD_CTGR_TRNS_OGNL")
    .withColumn("LEN", F.length(F.col("TX_ANOT_CTGR_TRNS")))
    .where(F.col("LEN") <= 200)
    .drop("LEN")
)

# Substitui o comportamento esperado de add_ts apenas para colunas padrão de auditoria.
# Qualquer coluna não atendida continuará explícita na validação de contrato abaixo.
for campo in schema_destino.fields:
    if campo.name.upper() in {"TS_CAD", "TS_INC", "TS_ATL"} and campo.name not in df_final.columns:
        df_final = df_final.withColumn(
            campo.name,
            F.current_timestamp().cast(campo.dataType),
        )

colunas_faltantes = [
    coluna
    for coluna in colunas_destino
    if coluna not in df_final.columns
]

if colunas_faltantes:
    raise ValueError(
        "Contrato Hive não atendido. Colunas ausentes no DataFrame final: "
        f"{colunas_faltantes}"
    )

# A ordem final é definida pelo contrato físico da tabela Hive destino.
df_final = df_final.select(*colunas_destino)

df_final, qtd_final = materializar(
    df_final,
    "BLOCO 6 | Dataset final",
)

if qtd_final == 0:
    raise ValueError("Dataset final vazio. Publicação Hive bloqueada.")

if df_final.where(F.col("CD_CHV_REG").isNull()).limit(1).count() > 0:
    raise ValueError("CD_CHV_REG nula no dataset final. Publicação Hive bloqueada.")

logger.info(f"Dataset final validado com {qtd_final:,} linhas.")
df_final.printSchema()

# df_publico já foi consumido e o dataset final está materializado.
liberar(df_publico, "BLOCO 5 | Público enriquecido")


# COMMAND ----------
# %%spark
# BLOCO 7 — Publicação Hive e conferência de readback.
# Objetivo: substituir write_HIVE mantendo overwrite e 10 partições de escrita.
# O write consome o cache de df_final, sem refazer leituras JDBC no DB2.

(
    df_final
    .repartition(num_particoes_escrita_hive)
    .write
    .mode("overwrite")
    .insertInto(tabela_destino)
)

qtd_readback = spark.table(tabela_destino).count()

if qtd_readback != qtd_final:
    raise ValueError(
        "Readback divergente após a publicação Hive: "
        f"esperado={qtd_final}, obtido={qtd_readback}"
    )

logger.info(
    f"Publicação concluída: {tabela_destino} | linhas={qtd_readback:,}"
)


